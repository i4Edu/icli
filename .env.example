# Required: GitHub Personal Access Token with `models:read` scope.
# Fine-grained PAT or classic PAT both work. GH_TOKEN is also accepted.
GITHUB_TOKEN=your_github_token_here

# Optional overrides
# ICOPILOT_MODEL=gpt-4o-mini
#
# Provider selection. Default is "github" (GitHub Models). Set to "copilot" to use
# the GitHub Copilot API (https://api.business.githubcopilot.com) like the official
# Copilot CLI — your GitHub token is automatically exchanged for a Copilot token,
# so the same GITHUB_TOKEN works (requires an active Copilot subscription).
# ICOPILOT_PROVIDER=copilot
#
# ICOPILOT_ENDPOINT defaults to https://models.inference.ai.azure.com (GitHub Models).
# Only override this for a custom OpenAI-compatible endpoint. Do NOT point it at
# https://api.business.githubcopilot.com manually with a PAT — use
# ICOPILOT_PROVIDER=copilot instead so the token exchange runs.
# ICOPILOT_ENDPOINT=https://models.inference.ai.azure.com



